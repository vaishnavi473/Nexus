{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A social media post",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "userPhotoURL": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "text", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "userPhotoURL": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "username", "text", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship between two users",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followedId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followedId", "createdAt"]
    },
    "PostEdit": {
      "title": "PostEdit",
      "description": "A record of a post's previous content",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "A user-submitted report for a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "reporterId": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "reporterId", "reason", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Public timeline posts"
    },
    "posts/{postId}/edits/{editId}": {
      "schema": "PostEdit",
      "description": "History of edits for a post"
    },
    "posts/{postId}/likes/{userId}": {
      "schema": "Like",
      "description": "Likes on a specific post"
    },
    "posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a specific post"
    },
    "follows/{followId}": {
      "schema": "Follow",
      "description": "User follow relationships"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User saved posts"
    },
    "reports/{reportId}": {
      "schema": "Report",
      "description": "User submitted reports"
    }
  }
}
