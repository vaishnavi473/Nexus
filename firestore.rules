rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow get: if true;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email', 'createdAt'])
        && data.keys().size() <= 6
        && data.uid == request.auth.uid
        && data.username is string && data.username.size() >= 3 && data.username.size() <= 30
        && data.email is string && data.email.size() <= 100
        && (data.bio == null || (data.bio is string && data.bio.size() <= 160))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
        && data.createdAt == request.time;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['userId', 'username', 'text', 'likesCount', 'commentsCount', 'createdAt'])
        && data.keys().size() <= 8
        && data.userId == request.auth.uid
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
        && data.likesCount is number
        && data.commentsCount is number
        && data.createdAt == request.time;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['postId', 'userId', 'username', 'text', 'createdAt'])
        && data.keys().size() <= 6
        && data.userId == request.auth.uid
        && data.text is string && data.text.size() > 0 && data.text.size() <= 500
        && data.createdAt == request.time;
    }

    function isValidLike(data) {
      return data.keys().hasAll(['postId', 'userId', 'createdAt'])
        && data.keys().size() == 3
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidFollow(data) {
      return data.keys().hasAll(['followerId', 'followedId', 'createdAt'])
        && data.keys().size() == 3
        && data.followerId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidBookmark(data) {
      return data.keys().hasAll(['userId', 'postId', 'createdAt'])
        && data.keys().size() == 3
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidPostEdit(data) {
      return data.keys().hasAll(['text', 'createdAt'])
        && data.keys().size() == 2
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
        && data.createdAt == request.time;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['postId', 'reporterId', 'reason', 'createdAt'])
        && data.keys().size() == 4
        && data.reporterId == request.auth.uid
        && data.reason is string && data.reason.size() > 0 && data.reason.size() <= 1000
        && data.createdAt == request.time;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['recipientId', 'senderId', 'senderName', 'type', 'read', 'createdAt'])
        && data.keys().size() >= 6
        && data.senderId == request.auth.uid
        && data.read == false
        && data.createdAt == request.time;
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidUser(request.resource.data);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['username', 'bio', 'photoURL'])
        // Simplified validation for update for brevity in rule helper, 
        // but normally we check types here too.
        && request.resource.data.username is string && request.resource.data.username.size() >= 3;
    }

    match /posts/{postId} {
      allow get: if true;
      allow list: if true; // Public feed
      allow create: if isSignedIn() && isValidPost(request.resource.data);
      allow update: if isSignedIn() && (
        // Case 1: Author updates their post (edit action: only text)
        (isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text']))
        || 
        // Case 2: System update for user metadata sync (username/photoURL)
        (isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userPhotoURL', 'username', 'text', 'imageUrl'])) 
        ||
        // Case 3: System update for likes/comments count
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount']))
      );
      allow delete: if isSignedIn() && isOwner(resource.data.userId);

      match /likes/{userId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && isValidLike(request.resource.data) && userId == request.auth.uid;
        allow delete: if isSignedIn() && isOwner(userId);
      }

      match /comments/{commentId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && isValidComment(request.resource.data);
        allow delete: if isSignedIn() && isOwner(resource.data.userId);
      }

      match /edits/{editId} {
        allow list: if true;
        allow create: if isSignedIn() && isOwner(get(/databases/$(database)/documents/posts/$(postId)).data.userId) && isValidPostEdit(request.resource.data);
      }
    }

    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidFollow(request.resource.data);
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(request.resource.data);
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
    }

    match /bookmarks/{bookmarkId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidBookmark(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && isValidReport(request.resource.data);
    }
  }
}
